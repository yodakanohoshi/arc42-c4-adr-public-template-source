digraph G {
  graph [rankdir=LR, bgcolor="transparent", pad="0.3", nodesep="0.5", ranksep="0.7", fontname="Noto Sans CJK JP"];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK JP", fontsize=14, color="#2f5d7c", fillcolor="#eef5fa", margin="0.18,0.12"];
  edge [fontname="Noto Sans CJK JP", fontsize=11, color="#52606d", arrowsize=0.8];
  arc [label="arc42\n文書全体の構造と入口", fillcolor="#d9edf7"];
  c4 [label="C4\n境界・構造・配置の図", fillcolor="#e8f5e9"];
